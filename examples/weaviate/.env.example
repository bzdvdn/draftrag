# draftRAG weaviate example
#
# Быстрый старт:
#   docker compose up -d
#   cp .env.example .env && go run .
#
# Полный список переменных окружения см. в examples/shared/config.go.

# LLM провайдер: mock (по умолчанию, не требует ключей), ollama, openai, anthropic
LLM_PROVIDER=mock

# Размерность эмбеддингов (должна совпадать с моделью)
EMBEDDING_DIM=1536

# URL Weaviate сервера (опционально, по умолчанию http://localhost:8080)
# WEAVIATE_URL=http://localhost:8080

# Имя класса (опционально, по умолчанию DraftragChunk)
# COLLECTION_NAME=DraftragChunk

# Опционально: настройки Ollama (только при LLM_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_LLM_MODEL=llama3.2

# Опционально: настройки OpenAI (только при LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_LLM_MODEL=gpt-4o-mini
